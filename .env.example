# Supabase — Dashboard > Settings > API
SUPABASE_URL=
SUPABASE_ANON_KEY=          # chave pública (anon), usada no frontend
SUPABASE_SERVICE_ROLE_KEY=  # chave secreta, SOMENTE no backend (webhook)

# Payt — a "chave única" que você cadastra no painel da Payt
PAYT_TOKEN=

# URL pública do site (sem barra no final)
# Ex: https://meutreinamento.vercel.app
SITE_URL=
